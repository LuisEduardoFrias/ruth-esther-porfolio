
---
import Layout from '@/layouts/Layout.astro'
import { ClientRouter } from 'astro:transitions';
export const prerender = true;

export function getStaticPaths() {
  return [
    { params: { id: 'people-group' } },
    { params: { id: 'camera-qa' } },
    { params: { id: 'camera-secretary' } },
    { params: { id: 'protocol-officer' } },
  ];
}

const { id } = Astro.params;

const EXPERIENCE_NAV = [
   { id: "people-group", name: "Data Analyst", href: "/experience/people-group" },
   { id: "camera-qa", name: "QA Analyst", href: "/experience/camera-qa" },
   { id: "camera-secretary", name: "Secretary", href: "/experience/camera-secretary" },
   { id: "protocol-officer", name: "Protocol Officer", href: "/experience/protocol-officer" },
];
---

<Layout title="Experience Details">
  <ClientRouter />

  <div class="w-full max-w-6xl mx-auto">
    
    <nav 
      id="nav-container"
      class="flex w-full overflow-x-auto no-scrollbar gap-3 mb-8 p-3 bg-white/50 backdrop-blur-md rounded-2xl border border-purple-100 scroll-smooth shadow-sm"
    >
      {EXPERIENCE_NAV.map((exp) => (
        <a 
          data-translate_key={"experience_" + exp.id}
          href={exp.href}
          class={id === exp.id 
            ? "active-exp flex-none px-5 py-2.5 rounded-xl font-semibold whitespace-nowrap transition-all duration-300 bg-purple-600 text-white shadow-lg scale-105" 
            : "flex-none px-5 py-2.5 rounded-xl font-semibold whitespace-nowrap transition-all duration-300 bg-white text-purple-800 hover:bg-purple-50 border border-purple-100"
          }
        >
          {exp.name}
        </a>
      ))}
    </nav>

    <div class="experience-content">
      {id === 'people-group' && (
         <section class="p-6 md:p-10 bg-white rounded-3xl shadow-xl border border-gray-100 animate-fade-in">
            <h1 data-translate_key="experience_data_analytics_title" class="text-3xl font-bold text-purple-800 mb-2 border-l-4 border-purple-600 pl-4">Data Analyst</h1>
            <h2 data-translate_key="experience_data_analytics_company" class="text-xl text-gray-600 mb-6 pl-5">People Group Dominicana</h2>
            <div data-translate_key="experience_data_analytics_area" class="text-sm bg-purple-50 text-purple-700 px-4 py-2 rounded-lg inline-block mb-6 ml-5 font-medium">
               Area: Operations / Commercial
            </div>
            <p data-translate_key="experience_data_analytics_detail" class="text-gray-700 leading-relaxed mb-4">
               Specialized in KPI management and data transformation for strategic decision-making:
            </p>
            <ul class="list-disc pl-8 space-y-2 text-gray-700">
               <li data-translate_key="experience_data_analytics_tasks1" >Management and monitoring of Key Performance Indicators (KPIs) and executive reports.</li>
               <li data-translate_key="experience_data_analytics_tasks2" >Exhaustive data cleaning and preparation processes (Data Wrangling).</li>
               <li data-translate_key="experience_data_analytics_tasks3" >Creation of dynamic dashboards for commercial metrics visualization.</li>
            </ul>
         </section>
      )}

      {id === 'camera-qa' && (
         <section class="p-6 md:p-10 bg-white rounded-3xl shadow-xl border border-gray-100 animate-fade-in">
            <h1 data-translate_key="experience_camara_qa_title" class="text-3xl font-bold text-purple-800 mb-2 border-l-4 border-purple-600 pl-4">Software Quality Analyst</h1>
            <h2 data-translate_key="experience_camara_qa_company" class="text-xl text-gray-600 mb-6 pl-5">Chamber of Accounts</h2>
            <div data-translate_key="experience_camara_qa_area" class="text-sm bg-purple-50 text-purple-700 px-4 py-2 rounded-lg inline-block mb-6 ml-5 font-medium">
               Department: Technology
            </div>
            <p data-translate_key="experience_camara_qa_detail" class="text-gray-700 leading-relaxed mb-4">
               Responsible for ensuring the quality and correct operation of institutional technological platforms:
            </p>
            <ul class="list-disc pl-8 space-y-2 text-gray-700">
               <li data-translate_key="experience_camara_qa_tasks1" >Execution of exhaustive manual tests to verify system integrity.</li>
               <li data-translate_key="experience_camara_qa_tasks2" >Validation of software requirements and error detection in early stages.</li>
               <li data-translate_key="experience_camara_qa_tasks3" >Detailed documentation of test cases and technical manuals for internal systems.</li>
            </ul>
         </section>
      )}

      {id === 'camera-secretary' && (
         <section class="p-6 md:p-10 bg-white rounded-3xl shadow-xl border border-gray-100 animate-fade-in">
            <h1 data-translate_key="experience_secret_title" class="text-3xl font-bold text-purple-800 mb-2 border-l-4 border-purple-600 pl-4">Secretary</h1>
            <h2 data-translate_key="experience_secret_company" class="text-xl text-gray-600 mb-6 pl-5">Chamber of Accounts</h2>
            <div data-translate_key="experience_secret_area" class="text-sm bg-purple-50 text-purple-700 px-4 py-2 rounded-lg inline-block mb-6 ml-5 font-medium">
               Communications Department
            </div>
            <p data-translate_key="experience_secret_detail" class="text-gray-700 leading-relaxed mb-4">
               Key administrative support for the management and workflow of the communications department:
            </p>
            <ul class="list-disc pl-8 space-y-2 text-gray-700">
               <li data-translate_key="experience_secret_tasks1" >Administrative agenda management for the department manager.</li>
               <li data-translate_key="experience_secret_tasks2" >Control of institutional correspondence and drafting of official documents.</li>
               <li data-translate_key="experience_secret_tasks3" >Support in organizing minutes and recording departmental activities.</li>
            </ul>
         </section>
      )}

      {id === 'protocol-officer' && (
         <section class="p-6 md:p-10 bg-white rounded-3xl shadow-xl border border-gray-100 animate-fade-in">
            <h1 data-translate_key="experience_min_pro_title" class="text-3xl font-bold text-purple-800 mb-2 border-l-4 border-purple-600 pl-4">Protocol Officer</h1>
            <h2 data-translate_key="experience_min_pro_company" class="text-xl text-gray-600 mb-6 pl-5">Ministry of Interior and Police</h2>
            <p data-translate_key="experience_min_pro_detail" class="text-gray-700 leading-relaxed mb-4">
               Coordination and management of protocol standards in institutional events and activities:
            </p>
            <ul class="list-disc pl-8 space-y-2 text-gray-700">
               <li data-translate_key="experience_min_pro_tasks1" >Organization and supervision of protocol logistics in official ceremonies.</li>
               <li data-translate_key="experience_min_pro_tasks2" >Reception and attendance of authorities and special delegations.</li>
               <li data-translate_key="experience_min_pro_tasks3" >Assistance in planning ministerial events ensuring compliance with courtesy standards.</li>
            </ul>
         </section>
      )}
    </div>

    <div class="flex justify-between items-center mt-10 px-2 pb-10">
        <a 
          data-translate_key="experience_btn_prev"
          id="prevBtn" 
          class="flex items-center gap-2 px-6 py-3 border-2 border-purple-600 text-purple-600 rounded-full hover:bg-purple-600 hover:text-white transition-all cursor-pointer font-medium"
        >
            <span>←</span> Previous
        </a>
        <a 
          data-translate_key="experience_btn_next"
          id="nextBtn" 
          class="flex items-center gap-2 px-6 py-3 bg-purple-600 text-white rounded-full hover:bg-purple-700 shadow-md transition-all cursor-pointer font-medium"
        >
            Next <span>→</span>
        </a>
    </div>
  </div>
</Layout>

<style>
  #nav-container {
    max-width: 100%;
    display: flex;
    flex-wrap: nowrap;
    -webkit-overflow-scrolling: touch;
  }

  .no-scrollbar::-webkit-scrollbar { 
    display: none; 
  }
  
  .no-scrollbar { 
    -ms-overflow-style: none; 
    scrollbar-width: none; 
  }

  .animate-fade-in {
    animation: fadeIn 0.4s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  function setupExperienceNav() {
    const experiences = ["people-group", "camera-qa", "camera-secretary", "protocol-officer"];
    const pathParts = window.location.pathname.split('/');
    const currentId = pathParts[pathParts.length - 1];
    const currentIndex = experiences.indexOf(currentId);

    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');

    if (prevBtn) {
      if (currentIndex > 0) {
        prevBtn.setAttribute('href', "/experience/" + experiences[currentIndex - 1]);
        prevBtn.style.opacity = "1";
        prevBtn.style.pointerEvents = "auto";
      } else {
        prevBtn.style.opacity = "0.3";
        prevBtn.style.pointerEvents = "none";
      }
    }

    if (nextBtn) {
      if (currentIndex < experiences.length - 1) {
        nextBtn.setAttribute('href', "/experience/" + experiences[currentIndex + 1]);
        nextBtn.style.opacity = "1";
        nextBtn.style.pointerEvents = "auto";
      } else {
        nextBtn.style.opacity = "0.3";
        nextBtn.style.pointerEvents = "none";
      }
    }

    setTimeout(function() {
      const activeLink = document.querySelector('.active-exp');
      if (activeLink) {
        activeLink.scrollIntoView({
          behavior: 'smooth',
          block: 'nearest',
          inline: 'center'
        });
      }
    }, 100);
  }

  document.addEventListener('astro:page-load', setupExperienceNav);
</script>
