---
// Componente Sobre Mi - Ruth Esther
import Layout from '@/layouts/Layout.astro'
import IconExcel from '../assets/svg/IconExcel.svg?raw'
import IconPython from '../assets/svg/IconPython.svg?raw'
import IconMssql from '../assets/svg/IconMssql.svg?raw'
import IconPowerbi from '../assets/svg/IconPowerbi.svg?raw'
---

<Layout title="Sobre Mí | Ruth Esther" description="Portafolio profesional de Ruth Esther, Data Analyst.">
   <section id="sobre-mi" class="p-6 md:p-10 max-w-6xl mx-auto bg-transparent">
     <div class="flex flex-col gap-8">
       
       <div class="flex flex-col gap-4">
         <h3 class="text-2xl font-bold text-tm-pr border-b-2 border-tm-pr w-fit pb-1">
           Mi Perfil
         </h3>
         <p class="text-lg card p-4 text-tm-text2 leading-relaxed animate-fade-in">
            Analista de Datos con sólida experiencia en procesos <b class="text-tm-pr">ETL</b>, creación de <b class="text-tm-pr">dashboards dinámicos</b> y gestión de bases de datos mediante
            <b class="text-tm-pr">DDL</b> y <b class="text-tm-pr">DML</b> diseño de <b class="text-tm-pr">KPIs de rendimiento</b> para evaluar el desempeño operativo. Mi enfoque se centra en transformar datos complejos 
            en información estratégica que impulse el crecimiento organizacional.
            Con formación en <b class="text-tm-pr">Desarrollo de Software</b>, combino la lógica de programación con el análisis estadístico para ofrecer soluciones
            precisas y escalables.
         </p>
       </div>
   
       <div class="flex flex-col gap-4">
         <h3 class="text-2xl font-bold text-tm-pr border-b-2 border-tm-pr w-fit pb-1">
           Herramientas y Expertise
         </h3>
         <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
           
           <div class="flex items-start gap-3 p-4 rounded-xl bg-tm-bg-50 border border-tm-pr/10 hover:border-tm-pr transition-all animate-fade-in">
             <div class="w-8 h-8 text-tm-pr shrink-0" set:html={IconExcel} />
             <div>
               <h4 class="font-bold text-tm-se leading-none mb-1">Excel Avanzado</h4>
               <p class="text-xs text-tm-text2">Macros, Tablas Dinámicas, Análisis complejo de datos y Modelado financiero.</p>
             </div>
           </div>
   
            <div class="flex items-start gap-3 p-4 rounded-xl bg-tm-bg-50 border border-tm-pr/10 hover:border-tm-pr transition-all min-h-[100px] animate-fade-in">
                <div class="w-8 h-8 text-tm-pr shrink-0" set:html={IconMssql} />
                <div class="overflow-hidden">
                  <h4 class="font-bold text-tm-se leading-tight mb-1">SQL Server</h4>
                  <p class="text-xs text-tm-text2">Gestión de DML/DDL, consultas optimizadas y arquitectura de datos.</p>
                </div>
            </div>
   
           <div class="flex items-start gap-3 p-4 rounded-xl bg-tm-bg-50 border border-tm-pr/10 hover:border-tm-pr transition-all animate-fade-in">
             <div class="w-8 h-8 text-tm-pr shrink-0" set:html={IconPowerbi} />
             <div>
               <h4 class="font-bold text-tm-se leading-none mb-1">Power BI</h4>
               <p class="text-xs text-tm-text2">Dashboards de KPIs en tiempo real, visualización de datos, creación de reportes interactivos.</p> <!--y storytelling de datos-->
             </div>
           </div>
   
           <div class="flex items-start gap-3 p-4 rounded-xl bg-tm-bg-50 border border-tm-pr/10 hover:border-tm-pr transition-all animate-fade-in">
             <div class="w-8 h-8 text-tm-pr shrink-0" set:html={IconPython} />
             <div>
               <h4 class="font-bold text-tm-se leading-none mb-1">Python (Pandas)</h4>
               <p class="text-xs text-tm-text2">Limpieza de datos a gran escala, automatización de tareas y desarrollo de lógica</p>
             </div>
           </div>
         </div>
       </div>
   
       <div class="flex flex-col md:flex-row gap-8">
         <div class="flex-1">
           <h3 class="text-2xl font-bold text-tm-pr border-b-2 border-tm-pr w-fit pb-1 mb-4">
             Idiomas
           </h3>
            <div class="flex items-center gap-2">
             <span class="font-bold text-tm-se uppercase">Español:</span>
             <span class="px-3 py-1 bg-tm-pr/10 text-tm-pr rounded-full text-sm font-medium">Nativo</span>
           </div>
           <div class="flex items-center gap-2">
             <span class="font-bold text-tm-se uppercase">Inglés:</span>
             <span class="px-3 py-1 bg-tm-pr/10 text-tm-pr rounded-full text-sm font-medium">Nivel Intermedio</span>
           </div>
         </div>
   
         <div class="flex-1">
           <h3 class="text-2xl font-bold text-tm-pr border-b-2 border-tm-pr w-fit pb-1 mb-4">
             Visión y Propósito
           </h3>
           <p class="card p-4 text-tm-text2 leading-relaxed animate-fade-in">
             Mi motor es la <b class="text-tm-pr">evolución constante</b>. No solo busco analizar datos, sino dominar nuevas tecnologías que me permitan predecir el
             futuro de los negocios. Me apasiona el aprendizaje autodidacta y mi meta es convertirme en una referente del <b class="text-tm-pr">Data Science</b>, aportando soluciones
             disruptivas que rompan con lo convencional en entornos de alto rendimiento.
           </p>
         </div>
       </div>
     </div>
   </section>
</Layout>
