---
import Layout from '@/layouts/Layout.astro'
import Whatsapp from '../assets/svg/IconWhatsApp.svg?raw'
---

<Layout title="Contactos" description="Portafolio profesional de Ruth Esther, Data Analyst.">
   <div class="flex flex-col items-start gap-3 p-4 max-w-6xl mx-auto rounded-xl bg-tm-bg-50 border border-tm-pr/10 hover:border-tm-pr transition-all animate-fade-in">
      <h2 data-translate_key="contact_title" class="text-2xl font-bold tracking-widest uppercase mb-6 border-b border-[#1a2e5a]/20 pb-2">
       Contact
     </h2>
   
     <div class="space-y-4 flex flex-col gap-4 mb-8">
       <div class="flex items-center gap-8">
         <div class="flex items-center gap-4">
            <div class="w-6 flex justify-center text-xl">📞</div>
            <a href="tel:8493565151" class="hover:underline">849-356-5151</a>
         </div>
         <button class="whatsappIcon flex gap-2 items-center">
            <div class="p-0" set:html={Whatsapp}></div>
            <span data-translate_key="contact_whatsapp" >click me</span>
         </button>
       </div>
   
       <div class="flex items-center gap-4">
         <div class="w-6 flex justify-center text-xl">✉️</div>
         <a href="mailto:ruthbaezortiz10@gmail.com" class="hover:underline lowercase">ruthbaezortiz10@gmail.com</a>
       </div>
   
       <div class="flex items-center gap-4">
         <div class="w-6 flex justify-center text-xl">🌐</div>
         <a href="http://ruth-esther-porfolio.vercel.app/" target="_blank" class="hover:underline break-all italic">
           ruth-esther-porfolio.vercel.app/
         </a>
       </div>
   
       <div class="flex items-start gap-4">
         <div class="w-6 flex justify-center text-xl pt-1">📍</div>
         <div>
           <p class="font-semibold text-[#1a2e5a]">Santo Domingo Este</p>
           <p class="text-sm opacity-90">Kennedy II Almirante</p>
         </div>
       </div>
     </div>
   </div>
</Layout>

<script>
   import { $ } from '@/lib/dom-selector'
   const CELL_NUMBER = 8493565151
   const $whatsapp = $('.whatsappIcon');

   if ($whatsapp) {
      $whatsapp.addEventListener('click', () => window.open(`https://wa.me/${CELL_NUMBER}`, '_blank'));
   }
</script>