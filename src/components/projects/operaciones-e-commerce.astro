---
import Layout from '@/layouts/Layout.astro'
import Nota from '@/components/Nota.astro'
---

   <section class="p-6 md:p-8 lg:p-10 bg-white rounded-lg shadow-lg">
      <h1 data-translate_key="eco_title" class="text-3xl font-bold text-purple-800 mb-6 border-l-4 border-purple-600 pl-4">
         Comprehensive E-commerce Operations Analysis
      </h1>

      <p data-translate_key="eco_intro" class="mb-6 text-gray-700 leading-relaxed">
         This project represents a <strong class="text-purple-700">360-degree analysis</strong> of a large e-commerce platform's operations. 
         My role was to build a comprehensive report to understand overall business performance, 
         from <strong class="text-purple-700">product profitability</strong> to <strong class="text-purple-700">customer satisfaction</strong> 
         and <strong class="text-purple-700">supply chain efficiency</strong>. 
         The project integrates <strong class="text-purple-700">SQL Server</strong> for database management and 
         <strong class="text-purple-700">Power BI</strong> for modeling, analysis, and visualization.
      </p>

      <div class="mb-8">
         <h2 data-translate_key="eco_demo_title" class="text-2xl font-semibold text-gray-800 mb-4">Interactive Demonstration</h2>
         <p data-translate_key="eco_demo_text" class="text-gray-600 mb-4">
            Here you can explore a glimpse of the different dashboard sections I developed. Use the buttons to navigate between "Executive", "Products", and "Customers/Geography" views.
         </p>

         <div class="flex justify-center gap-4 mb-6">
            <button id="btn-exec-dashboard" data-translate_key="eco_btn_exec" class="px-6 py-2 rounded-md font-semibold text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:ring-opacity-75 transition-colors duration-200">
               Executive
            </button>
            <button id="btn-prod-dashboard" data-translate_key="eco_btn_prod" class="px-6 py-2 rounded-md font-semibold text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:ring-opacity-75 transition-colors duration-200">
               Products
            </button>
            <button id="btn-client-geo-dashboard" data-translate_key="eco_btn_geo" class="px-6 py-2 rounded-md font-semibold text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:ring-opacity-75 transition-colors duration-200">
               Customers & Geography
            </button>
         </div>
         
         <div class="relative min-h-[400px] flex justify-center items-center">
            <div id="img-dash-exec" >
               <div class="flex flex-col gap-2 p-3 border border-gray-200 rounded-md bg-gray-50">
                  <label data-translate_key="eco_label_payment" class="font-medium text-gray-700">Payment Methods</label>
                
                  <div class="flex flex-wrap gap-4">
                     <label for="radio-general" class="flex items-center gap-2 text-sm text-gray-800 cursor-pointer hover:text-purple-700 transition-colors duration-200">
                        <input id="radio-general" data-img="dash-1" checked name="metodo_pago" class="accent-purple-700 w-4 h-4" type="radio"> 
                        <span data-translate_key="eco_pay_general">General</span>
                     </label>
                   
                     <label for="radio-tarjeta" class="flex items-center gap-2 text-sm text-gray-800 cursor-pointer hover:text-purple-700 transition-colors duration-200">
                        <input id="radio-tarjeta" data-img="dash-2" name="metodo_pago" class="accent-purple-700 w-4 h-4" type="radio"> 
                        <span data-translate_key="eco_pay_card">Card</span>
                     </label>
                   
                     <label for="radio-paypal" class="flex items-center gap-2 text-sm text-gray-800 cursor-pointer hover:text-purple-700 transition-colors duration-200">
                        <input id="radio-paypal" data-img="dash-3" name="metodo_pago" class="accent-purple-700 w-4 h-4" type="radio"> 
                        <span data-translate_key="eco_pay_paypal">PayPal</span>
                     </label>
                    
                     <label for="radio-transferencia" class="flex items-center gap-2 text-sm text-gray-800 cursor-pointer hover:text-purple-700 transition-colors duration-200">
                        <input id="radio-transferencia" data-img="dash-4" name="metodo_pago" class="accent-purple-700 w-4 h-4" type="radio"> 
                        <span data-translate_key="eco_pay_transfer">Transfer</span>
                     </label>
                  </div>
               </div>
               <img id="img-dash-1" src="/images/e-commerce-ejecutivo-1.jpg" class="w-full h-auto object-contain rounded-md shadow-md transition-opacity duration-300 ease-in-out" alt="Executive E-commerce Dashboard" />
               <img id="img-dash-2" src="/images/e-commerce-ejecutivo-2.jpg" class="hidden w-full h-auto object-contain rounded-md shadow-md transition-opacity duration-300 ease-in-out" alt="Executive E-commerce Dashboard" />
               <img id="img-dash-3" src="/images/e-commerce-ejecutivo-3.jpg" class="hidden w-full h-auto object-contain rounded-md shadow-md transition-opacity duration-300 ease-in-out" alt="Executive E-commerce Dashboard" />
               <img id="img-dash-4" src="/images/e-commerce-ejecutivo-4.jpg" class="hidden w-full h-auto object-contain rounded-md shadow-md transition-opacity duration-300 ease-in-out" alt="Executive E-commerce Dashboard" />
            </div>
            <img id="img-dash-prod" src="/images/e-commerce-productos_rentavilidad.jpg" class="w-full h-auto object-contain rounded-md shadow-md absolute top-0 left-0 hidden transition-opacity duration-300 ease-in-out" alt="E-commerce Product Analysis Dashboard" />
            <img id="img-dash-client-geo" src="/images/e-commerce-geografia_clientes.jpg" class="w-full h-auto object-contain rounded-md shadow-md absolute top-0 left-0 hidden transition-opacity duration-300 ease-in-out" alt="E-commerce Customers and Geography Dashboard" />
         </div>
      </div>
      
      <div class="mt-8 pt-6 border-t border-gray-200">
         <h2 data-translate_key="eco_context_title" class="text-2xl font-semibold text-gray-800 mb-4">Project Context and Requirements</h2>
         <p data-translate_key="eco_context_text" class="mb-4 text-gray-700 leading-relaxed">
            As part of the data analysis team for a large e-commerce platform, the goal was to provide a 360-degree view of the business, covering performance, customer satisfaction, supply chain efficiency, and product profitability.
         </p>
         
         <h3 data-translate_key="eco_skills_title" class="text-xl font-semibold text-gray-800 mb-3">Techniques and Demonstrated Skills:</h3>
         <ul class="list-disc list-inside space-y-2 text-gray-700 mb-6 pl-4">
            <li data-translate_key="eco_skill_1">
               <strong class="text-purple-700">Database Design and Management (SQL Server):</strong> Creation of the `EcommerceDB` database and definition of table schemas (`Customers`, `Products`, `Orders`, `Order_Details`) with primary and foreign keys, ensuring referential integrity.
            </li>
            <li data-translate_key="eco_skill_2">
               <strong class="text-purple-700">SQL View Optimization:</strong> Development of views like `Detailed_Sales_View` to simplify complex queries and optimize performance by combining information from multiple tables for Power BI analysis.
            </li>
            <li data-translate_key="eco_skill_3">
               <strong class="text-purple-700">Data Transformation (Power Query):</strong> Data processing to ensure quality and proper formatting, including the addition of temporal columns for period-based analysis.
            </li>
            <li data-translate_key="eco_skill_4">
               <strong class="text-purple-700">Calculated Columns and Advanced DAX Measures:</strong> Implementation of complex metrics to evaluate revenue, costs, and profit margins at the item and order level, as well as operational metrics (Total Units Sold, Total Orders, Average Order Value, Order Cancellation Rate) and customer metrics (Total Unique Customers, New Customers per Month/Year).
            </li>
            <li data-translate_key="eco_skill_5">
               <strong class="text-purple-700">Multi-Page Dashboard Design in Power BI:</strong> Creation of an interactive report with multiple pages (Executive, Products, and Customers/Geography) for a holistic business view, featuring key metric cards, trend charts, distributions, and detailed tables.
            </li>
            <li data-translate_key="eco_skill_6">
               <strong class="text-purple-700">Segmentation and Dynamic Interactions:</strong> Configuration of global slicers (Date, Product Category, Brand, Shipping Country, Customer Segment, Order Status) and adjustment of interactions between visualizations for dynamic analysis.
            </li>
         </ul>

         <p data-translate_key="eco_footer" class="text-gray-700 leading-relaxed">
            This report is a vital strategic tool that enables management to gain <strong class="text-purple-700">actionable insights</strong> into e-commerce performance, facilitating data-driven decisions to optimize profitability, operational efficiency, and customer satisfaction.
         </p>
      </div>
      
      <Nota />

   </section>

<style>

</style>

<script>
   import { $ } from '@/lib/dom-selector';

   const $btnExec = $('#btn-exec-dashboard');
   const $btnProd = $('#btn-prod-dashboard');
   const $btnClientGeo = $('#btn-client-geo-dashboard');
   
   const $btnGeneral = $('#radio-general');
   const $btnTarjeta = $('#radio-tarjeta');
   const $btnPaypal = $('#radio-paypal');
   const $btnTransferencia = $('#radio-transferencia');

   const $imgDashExec = $('#img-dash-exec');
   const $imgDashProd = $('#img-dash-prod');
   const $imgDashClientGeo = $('#img-dash-client-geo');

   const allImages = [$imgDashExec, $imgDashProd, $imgDashClientGeo];
   const allButtons = [$btnExec, $btnProd, $btnClientGeo];
   const allRadioButtons = [$btnGeneral, $btnTarjeta, $btnPaypal, $btnTransferencia];

   function selectedRadio(event){
      allRadioButtons.forEach(btn => {
         const id = `img-${btn.dataset.img}`;
         const $img = $(`#${id}`);
         $img.classList.add("hidden");
      });
      
      const id = `img-${event.target.dataset.img}`;
      const $img = $(`#${id}`);
      $img.classList.remove("hidden");
   }
   
   $btnGeneral.addEventListener('change',selectedRadio);
   $btnTarjeta.addEventListener('change',selectedRadio);
   $btnPaypal.addEventListener('change',selectedRadio);
   $btnTransferencia.addEventListener('change',selectedRadio);
   
   function showDashboard(dashboardType) {
      allImages.forEach(img => img.classList.add('hidden'));
      allButtons.forEach(btn => {
         btn.classList.remove('bg-purple-600', 'text-white');
         btn.classList.add('bg-purple-100', 'text-purple-800');
      });
      
      if (dashboardType === 'exec') {
         $imgDashExec.classList.remove('hidden');
         $btnExec.classList.remove('bg-purple-100', 'text-purple-800');
         $btnExec.classList.add('bg-purple-600', 'text-white');
      } else if (dashboardType === 'prod') {
         $imgDashProd.classList.remove('hidden');
         $btnProd.classList.remove('bg-purple-100', 'text-purple-800');
         $btnProd.classList.add('bg-purple-600', 'text-white');
      } else if (dashboardType === 'client-geo') {
         $imgDashClientGeo.classList.remove('hidden');
         $btnClientGeo.classList.remove('bg-purple-100', 'text-purple-800');
         $btnClientGeo.classList.add('bg-purple-600', 'text-white');
      }
   }

   $btnExec.addEventListener('click', () => showDashboard('exec'));
   $btnProd.addEventListener('click', () => showDashboard('prod'));
   $btnClientGeo.addEventListener('click', () => showDashboard('client-geo'));

   // Show Executive dashboard by default on page load
   showDashboard('exec');
</script>
