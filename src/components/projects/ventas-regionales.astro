---
import Layout from '@/layouts/Layout.astro'
import Nota from '@/components/Nota.astro'
---

<section class="p-6 md:p-8 lg:p-10 bg-white rounded-lg shadow-lg">
      <h1 data-translate_key="reg_sales_title" class="text-3xl font-bold text-purple-800 mb-6 border-l-4 border-purple-600 pl-4">
         Regional Sales Analysis
      </h1>

      <p data-translate_key="reg_sales_parag_1" class="mb-6 text-gray-700 leading-relaxed">
         In this project, I performed a comprehensive analysis of sales performance by region for a retail company. The main objective was to 
         <strong class="text-purple-700">identify patterns, trends, and growth opportunities</strong> in their operations. I used 
         <strong class="text-purple-700">Power BI</strong> for data ingestion, transformation, and visualization.
      </p>

      <div class="mb-8">
         <h2 data-translate_key="reg_sales_demo_title" class="text-2xl font-semibold text-gray-800 mb-4">Interactive Demonstration</h2>
         <p data-translate_key="reg_sales_demo_text" class="text-gray-600 mb-4">
            Here you can explore the interactive dashboard I developed. Use the "Category" and "Region" filters to see how the data and visualizations change.
         </p>

         <div class="flex flex-col gap-4 mb-6 overflow-x-scroll no-scrollbar">
            
            <div class="flex flex-col gap-2 p-3 border border-gray-200 rounded-md bg-gray-50">
               <label data-translate_key="reg_sales_label_cat" class="font-medium text-gray-700">Category</label>
               <div class="flex flex-wrap gap-4">
                  <label for="radio-elect" class="flex items-center gap-2 text-sm text-gray-800 cursor-pointer hover:text-purple-700 transition-colors duration-200">
                     <input id="radio-elect" checked name="categoria" class="accent-purple-700 w-4 h-4" type="radio"> 
                     <span data-translate_key="reg_sales_cat_elect">Electronics</span>
                  </label>
                
                  <label for="radio-ropa" class="flex items-center gap-2 text-sm text-gray-800 cursor-pointer hover:text-purple-700 transition-colors duration-200">
                     <input id="radio-ropa" name="categoria" class="accent-purple-700 w-4 h-4" type="radio"> 
                     <span data-translate_key="reg_sales_cat_cloth">Clothing</span>
                  </label>
                 
                  <label for="radio-hogar" class="flex items-center gap-2 text-sm text-gray-800 cursor-pointer hover:text-purple-700 transition-colors duration-200">
                     <input id="radio-hogar" name="categoria" class="accent-purple-700 w-4 h-4" type="radio"> 
                     <span data-translate_key="reg_sales_cat_home">Home</span>
                  </label>
               </div>
            </div>

            <div id="region-container" class="hidden flex flex-col gap-2 p-3 border border-gray-200 rounded-md bg-gray-50">
               <label data-translate_key="reg_sales_label_reg" class="font-medium text-gray-700">Region</label>
               <div class="flex flex-wrap gap-4">
                  <label for="radio-todos" class="text-sm flex items-center gap-2 text-gray-800 cursor-pointer hover:text-purple-700">
                     <input id="radio-todos" checked name="region" class="accent-purple-700 w-4 h-4" type="radio"> 
                     <span data-translate_key="reg_sales_reg_all">All</span>
                  </label>
                  <label for="radio-este" class="text-sm flex items-center gap-2 text-gray-800 cursor-pointer hover:text-purple-700">
                     <input id="radio-este" name="region" class="accent-purple-700 w-4 h-4" type="radio"> 
                     <span data-translate_key="reg_sales_reg_east">East</span>
                  </label>
                  <label for="radio-norte" class="text-sm flex items-center gap-2 text-gray-800 cursor-pointer hover:text-purple-700">
                     <input id="radio-norte" name="region" class="accent-purple-700 w-4 h-4" type="radio"> 
                     <span data-translate_key="reg_sales_reg_north">North</span>
                  </label>
                  <label for="radio-oeste" class="text-sm flex items-center gap-2 text-gray-800 cursor-pointer hover:text-purple-700">
                     <input id="radio-oeste" name="region" class="accent-purple-700 w-4 h-4" type="radio"> 
                     <span data-translate_key="reg_sales_reg_west">West</span>
                  </label>
                  <label for="radio-sur" class="text-sm flex items-center gap-2 text-gray-800 cursor-pointer hover:text-purple-700">
                     <input id="radio-sur" name="region" class="accent-purple-700 w-4 h-4" type="radio"> 
                     <span data-translate_key="reg_sales_reg_south">South</span>
                  </label>
               </div>
            </div>
         </div>
         
         <div class="w-full rounded-md shadow-md bg-gray-100 overflow-hidden min-h-[300px]">
            <img id="img-cat-1" src="/images/dashboardTienda-1.jpg" class="w-full h-auto object-contain block" alt="Electronics" />
            <img id="img-cat-2" src="/images/dashboardTienda-7.jpg" class="w-full h-auto object-contain hidden" alt="Clothing" />
            <img id="img-cat-3" src="/images/dashboardTienda-2.jpg" class="w-full h-auto object-contain hidden" alt="Home" />
            <img id="img-region-1" src="/images/dashboardTienda-3.jpg" class="w-full h-auto object-contain hidden" alt="East" />
            <img id="img-region-2" src="/images/dashboardTienda-4.jpg" class="w-full h-auto object-contain hidden" alt="North" />
            <img id="img-region-3" src="/images/dashboardTienda-5.jpg" class="w-full h-auto object-contain hidden" alt="West" />
            <img id="img-region-4" src="/images/dashboardTienda-6.jpg" class="w-full h-auto object-contain hidden" alt="South" />
         </div>
      </div>
      
      <div class="mt-8 pt-6 border-t border-gray-200">
         <h2 data-translate_key="reg_sales_context_title" class="text-2xl font-semibold text-gray-800 mb-4">Project Context and Requirements</h2>
         <p data-translate_key="reg_sales_context_text" class="mb-4 text-gray-700 leading-relaxed">
            As a data analyst at a retail company with stores in various regions, my task was to understand sales performance by region to identify trends and growth opportunities. The provided data included detailed sales information by `Sale_ID`, `Date`, `Region`, `City`, `Category`, `Product`, `Quantity`, and `Unit_Price`.
         </p>
         
         <h3 data-translate_key="reg_sales_skills_title" class="text-xl font-semibold text-gray-800 mb-3">Demonstrated Techniques and Skills:</h3>
         <ul class="list-disc list-inside space-y-2 text-gray-700 mb-6 pl-4">
            <li data-translate_key="reg_sales_skill_1"><strong class="text-purple-700">Data Modeling:</strong> Preparation and structuring of sales data for efficient analysis in Power BI.</li>
            <li data-translate_key="reg_sales_skill_2"><strong class="text-purple-700">DAX Measures Calculation:</strong> Creation of key measures such as <code class="bg-gray-100 text-purple-800 px-1 py-0.5 rounded text-sm">Total Sales</code>.</li>
            <li data-translate_key="reg_sales_skill_3"><strong class="text-purple-700">Interactive Visualization Design:</strong> Development of an intuitive dashboard with bar, line, and pie charts.</li>
            <li data-translate_key="reg_sales_skill_4"><strong class="text-purple-700">Slicers Implementation:</strong> Integration of filters by Region, Category, and Date.</li>
         </ul>

         <p data-translate_key="reg_sales_footer" class="text-gray-700 leading-relaxed">
            This analysis provided the company with crucial information for strategic decision-making.
         </p>
      </div>
      
      <Nota />
   </section>

<script>
   document.addEventListener('astro:page-load', () => {
      const getEl = (id) => document.getElementById(id);
      
      const radiosCat = document.querySelectorAll('input[name="categoria"]');
      const radiosReg = document.querySelectorAll('input[name="region"]');
      
      const images = {
         cat: [getEl('img-cat-1'), getEl('img-cat-2'), getEl('img-cat-3')],
         reg: [getEl('img-region-1'), getEl('img-region-2'), getEl('img-region-3'), getEl('img-region-4')]
      };

      function updateGallery() {
         const catChecked = (document.querySelector('input[name="categoria"]:checked') as HTMLInputElement)?.id;
         const regChecked = (document.querySelector('input[name="region"]:checked') as HTMLInputElement)?.id;

         // Ocultar todas las imágenes primero
         [...images.cat, ...images.reg].forEach(img => {
            if (img) {
               img.classList.remove('block');
               img.classList.add('hidden');
            }
         });

         // Lógica para mostrar la imagen correcta
         if (catChecked === 'radio-elect') {
            images.cat[0]?.classList.replace('hidden', 'block');
         } else if (catChecked === 'radio-ropa') {
            images.cat[1]?.classList.replace('hidden', 'block');
         } else if (catChecked === 'radio-hogar') {
            if (regChecked === 'radio-todos') {
               images.cat[2]?.classList.replace('hidden', 'block');
            } else if (regChecked === 'radio-este') {
               images.reg[0]?.classList.replace('hidden', 'block');
            } else if (regChecked === 'radio-norte') {
               images.reg[1]?.classList.replace('hidden', 'block');
            } else if (regChecked === 'radio-oeste') {
               images.reg[2]?.classList.replace('hidden', 'block');
            } else if (regChecked === 'radio-sur') {
               images.reg[3]?.classList.replace('hidden', 'block');
            }
         }
      }

      [...radiosCat, ...radiosReg].forEach(r => r.addEventListener('change', (e) => {
         const target = e.target as HTMLInputElement;
         // Si se cambia la categoría y no es "Hogar", resetear región a "Todos"
         if (target.name === 'categoria' && target.id !== 'radio-hogar') {
            const radioTodos = document.getElementById('radio-todos') as HTMLInputElement;
            if (radioTodos) radioTodos.checked = true;
         }
         updateGallery();
      }));

      updateGallery();
   });
</script>
