---
import Layout from '@/layouts/Layout.astro'
import Nota from '@/components/Nota.astro'
---

<section class="p-6 md:p-8 lg:p-10 bg-white rounded-lg shadow-lg">
      <h1 data-translate_key="prod_perf_title" class="text-3xl font-bold text-purple-800 mb-6 border-l-4 border-purple-600 pl-4">
         Product Performance Analysis
      </h1>

      <p data-translate_key="prod_perf_intro" class="mb-6 text-gray-700 leading-relaxed">
         This project focuses on the <strong class="text-purple-700">analysis of individual product performance</strong> within a company, 
         evaluating their <strong class="text-purple-700">sales, profit margins, and contribution to total revenue</strong>. 
         The goal is to provide a clear view of which products are most profitable and which need attention, 
         utilizing <strong class="text-purple-700">Power BI</strong> for detailed analysis.
      </p>

      <div class="mb-8">
         <h2 data-translate_key="prod_perf_demo_title" class="text-2xl font-semibold text-gray-800 mb-4">Interactive Demonstration</h2>
         <p data-translate_key="prod_perf_demo_text" class="text-gray-600 mb-4">
            Here you can explore the interactive dashboard I developed. Use the "Product" and "Date" filters to segment the data and gain specific insights.
         </p>

         <div class="flex flex-col gap-4 mb-6 overflow-x-scroll no-scrollbar">
            
            <div class="flex flex-col gap-2 p-3 border border-gray-200 rounded-md bg-gray-50">
               <label data-translate_key="prod_perf_label_product" class="font-medium text-gray-700">Product</label>
               <div class="flex flex-wrap gap-4">
                  <label for="prod-camiseta" class="flex items-center gap-2 text-sm text-gray-800 cursor-pointer hover:text-purple-700 transition-colors duration-200">
                     <input id="prod-camiseta" checked name="producto" class="accent-purple-700 w-4 h-4" type="radio"> <i data-translate_key="prod_perf_shirt">Shirt</i>
                  </label>
                  <label for="prod-pantalon" class="flex items-center gap-2 text-sm text-gray-800 cursor-pointer hover:text-purple-700 transition-colors duration-200">
                     <input id="prod-pantalon" name="producto" class="accent-purple-700 w-4 h-4" type="radio"> <i data-translate_key="prod_perf_pants">Pants</i>
                  </label>
                  <label for="prod-zapatos" class="flex items-center gap-2 text-sm text-gray-800 cursor-pointer hover:text-purple-700 transition-colors duration-200">
                     <input id="prod-zapatos" name="producto" class="accent-purple-700 w-4 h-4" type="radio"> <i data-translate_key="prod_perf_shoes">Shoes</i>
                  </label>
               </div>
            </div>
         </div>
         
         <div class="relative min-h-[300px] flex justify-center items-center">
            <img id="img-prod-camiseta" src="/images/camiza.jpg" class="w-full h-auto object-contain rounded-md shadow-md absolute top-0 left-0  transition-opacity duration-300 ease-in-out" alt="Product Performance Dashboard - Shirt" />
            <img id="img-prod-pantalon" src="/images/pantalon.jpg" class="w-full h-auto object-contain rounded-md shadow-md absolute top-0 left-0 hidden transition-opacity duration-300 ease-in-out" alt="Product Performance Dashboard - Pants" />
            <img id="img-prod-zapatos" src="/images/zapatos.jpg" class="w-full h-auto object-contain rounded-md shadow-md absolute top-0 left-0 hidden transition-opacity duration-300 ease-in-out" alt="Product Performance Dashboard - Shoes" />
         </div>
      </div>
      
      <div class="mt-8 pt-6 border-t border-gray-200">
         <h2 data-translate_key="prod_perf_context_title" class="text-2xl font-semibold text-gray-800 mb-4">Project Context and Requirements</h2>
         <p data-translate_key="prod_perf_context_text" class="mb-4 text-gray-700 leading-relaxed">
            As a data analyst, my goal was to analyze product performance in terms of sales, profit margin, and contribution to total revenue. Two tables were used: <code class="bg-gray-100 text-purple-800 px-1 py-0.5 rounded text-sm">Products</code> (with <code class="bg-gray-100 text-purple-800 px-1 py-0.5 rounded text-sm">Product_ID</code>, <code class="bg-gray-100 text-purple-800 px-1 py-0.5 rounded text-sm">Product_Name</code>, <code class="bg-gray-100 text-purple-800 px-1 py-0.5 rounded text-sm">Unit_Cost</code>) and <code class="bg-gray-100 text-purple-800 px-1 py-0.5 rounded text-sm">ProductSales</code> (with <code class="bg-gray-100 text-purple-800 px-1 py-0.5 rounded text-sm">Sale_ID</code>, <code class="bg-gray-100 text-purple-800 px-1 py-0.5 rounded text-sm">Date</code>, <code class="bg-gray-100 text-purple-800 px-1 py-0.5 rounded text-sm">Product_ID</code>, <code class="bg-gray-100 text-purple-800 px-1 py-0.5 rounded text-sm">Quantity</code>, <code class="bg-gray-100 text-purple-800 px-1 py-0.5 rounded text-sm">Sale_Price</code>).
         </p>
         
         <h3 data-translate_key="prod_perf_skills_title" class="text-xl font-semibold text-gray-800 mb-3">Techniques and Demonstrated Skills:</h3>
         <ul class="list-disc list-inside space-y-2 text-gray-700 mb-6 pl-4">
            <li data-translate_key="prod_perf_skill_1">
               <strong class="text-purple-700">Data Modeling and Relationships:</strong> Establishing relationships between tables for a cohesive analysis.
            </li>
            <li data-translate_key="prod_perf_skill_2">
               <strong class="text-purple-700">Calculated Column Creation:</strong> Development of row-level metrics such as <code class="bg-gray-100 text-purple-800 px-1 py-0.5 rounded text-sm">Total Revenue</code>, <code class="bg-gray-100 text-purple-800 px-1 py-0.5 rounded text-sm">Total Cost</code>, and <code class="bg-gray-100 text-purple-800 px-1 py-0.5 rounded text-sm">Profit Margin</code>.
            </li>
            <li data-translate_key="prod_perf_skill_3">
               <strong class="text-purple-700">DAX Aggregate Measure Calculation:</strong> Implementation of <code class="bg-gray-100 text-purple-800 px-1 py-0.5 rounded text-sm">Total Revenues</code>, <code class="bg-gray-100 text-purple-800 px-1 py-0.5 rounded text-sm">Total Profit Margin</code>, and <code class="bg-gray-100 text-purple-800 px-1 py-0.5 rounded text-sm">Margin Percentage</code> for performance summaries.
            </li>
            <li data-translate_key="prod_perf_skill_4">
               <strong class="text-purple-700">Key Visualization Design:</strong> Creation of bar charts for revenue and margin per product, scatter plots to compare metrics, and detailed tables with conditional formatting to highlight performance.
            </li>
            <li data-translate_key="prod_perf_skill_5">
               <strong class="text-purple-700">Slicer Implementation:</strong> Addition of filters by Product Name and Date for dynamic performance exploration.
            </li>
         </ul>

         <p data-translate_key="prod_perf_footer" class="text-gray-700 leading-relaxed">
            This analysis allows the company to <strong class="text-purple-700">identify high and low-performing products</strong>, facilitating strategic decisions on pricing, promotions, and inventory.
         </p>
      </div>
      
      <Nota />

   </section>


<script>
  // Usamos una función que se ejecute cuando el DOM esté listo
  document.addEventListener('astro:page-load', () => {
    const setupGallery = () => {
      const radios = document.querySelectorAll('input[name="producto"]');
      const imgCamiseta = document.getElementById('img-prod-camiseta');
      const imgPantalon = document.getElementById('img-prod-pantalon');
      const imgZapatos = document.getElementById('img-prod-zapatos');

      if (!imgCamiseta || !radios.length) return;

      const images = {
        'prod-camiseta': imgCamiseta,
        'prod-pantalon': imgPantalon,
        'prod-zapatos': imgZapatos
      };

      radios.forEach(radio => {
        radio.addEventListener('change', (e) => {
          const targetId = (e.target as HTMLInputElement).id;
          
          // Ocultar todas
          Object.values(images).forEach(img => {
            if (img) img.classList.add('hidden');
          });

          // Mostrar la seleccionada
          const selectedImg = images[targetId];
          if (selectedImg) {
            selectedImg.classList.remove('hidden');
            selectedImg.classList.add('block');
          }
        });
      });
    };

    setupGallery();
  });

  // Ejecución inmediata para la primera carga
  const radios = document.querySelectorAll('input[name="producto"]');
  radios.forEach(r => r.addEventListener('change', () => {
     const imgC = document.getElementById('img-prod-camiseta');
     const imgP = document.getElementById('img-prod-pantalon');
     const imgZ = document.getElementById('img-prod-zapatos');
     
     const selected = document.querySelector('input[name="producto"]:checked').id;
     
     [imgC, imgP, imgZ].forEach(i => i.classList.add('hidden'));
     document.getElementById('img-' + selected).classList.remove('hidden');
  }));
</script>
