---
import { EDUCATIONS } from '@/consts/educations';
---

<ul class="grid grid-cols-1 gap-8">
  {EDUCATIONS.map(({ key, title, institution, url, img, alt, date, details }, index) => {
    const imagePath = '/images/'+img+'.webp';
    const modalId = "modal-"+index;
   
      
    return (
      <li class=" w-full xl:w-1/2 bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden flex flex-col">
        {/* 1. Imagen (Primero) */}
        {img && (
          <div class="relative bg-gray-100">
            {url ? (
              <a href={url} target="_blank" rel="noopener noreferrer" class="block group">
                <img 
                  src={imagePath} 
                  alt={alt} 
                  class="w-full h-52 object-cover group-hover:opacity-90 transition-opacity" 
                />
                <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/10">
                   <span class="bg-white px-3 py-1 rounded-full text-xs font-bold shadow-sm">Visitar sitio</span>
                </div>
              </a>
            ) : (
              <button 
                data-open-modal={modalId}
                class="w-full p-0 border-none cursor-zoom-in block hover:opacity-95 transition-opacity"
              >
                <img src={imagePath} alt={alt} class="w-full h-96 object-cover object-top " />
              </button>
            )}
          </div>
        )}

        {/* 2. Contenido (Debajo) */}
        <div class="p-6 flex-grow">
          <h3 data-translate_key={key + "_title"} class="text-xl font-bold text-gray-900 leading-tight">
            {title}
          </h3>

          <div class="mt-1 flex items-center gap-2">
            {url ? (
              <a href={url} target="_blank" class="text-blue-600 hover:underline font-medium">
                {institution}
              </a>
            ) : (
              <span data-translate_key={key + "_detail"} class="text-gray-600">{institution}</span>
            )}
          </div>

          {date && <p class="text-sm text-gray-500 mt-1 italic">{date}</p>}

          {details && (
            <p class="text-sm text-gray-700 mt-4 leading-relaxed border-t border-gray-100 pt-4">
              {details}
            </p>
          )}
        </div>

        {/* Modal para imágenes sin URL externa */}
        {!url && img && (
         <dialog 
           id={modalId} 
           class="p-0 rounded-lg shadow-2xl backdrop:bg-black/75 backdrop:backdrop-blur-sm max-w-[95vw] max-h-[95vh] bg-transparent overflow-hidden fixed inset-0 m-auto"
         >
           <div class="relative w-full h-full flex items-center justify-center p-4">
             
             <form method="dialog">
               <button class="fixed top-6 right-6 z-[60] bg-black/60 hover:bg-black text-white rounded-full w-12 h-12 flex items-center justify-center transition-colors border border-white/20 text-xl">
                 ✕
               </button>
             </form>
         
             <div class="zoom-wrapper flex items-center justify-center overflow-hidden cursor-grab active:cursor-grabbing max-w-full max-h-full">
               <img 
                 src={imagePath} 
                 alt={alt} 
                 class="modal-img-zoom max-w-full max-h-[90vh] object-contain block transition-transform duration-150 ease-out shadow-2xl" 
               />
             </div>
         
           </div>
         </dialog>
        )}
      </li>
    );
  })}
</ul>

<script>
  function initEducationModals() {
    const modalTriggers = document.querySelectorAll('[data-open-modal]');
    
    modalTriggers.forEach(trigger => {
      const modalId = trigger.getAttribute('data-open-modal');
      const modal = document.getElementById(modalId) as HTMLDialogElement;
      const img = modal?.querySelector('.modal-img-zoom') as HTMLImageElement;
      
      if (!modal || !img) return;

      // Abrir modal
      trigger.addEventListener('click', () => {
        modal.showModal();
        document.body.style.overflow = 'hidden';
      });

      // Resetear al cerrar
      modal.addEventListener('close', () => {
        document.body.style.overflow = '';
        img.style.transform = `scale(1) translate(0px, 0px)`;
      });

      // --- Lógica de Zoom Simplificada ---
      let scale = 1;
      let pos = { x: 0, y: 0 };

      modal.addEventListener('wheel', (e) => {
        e.preventDefault();
        const delta = e.deltaY > 0 ? -0.2 : 0.2;
        scale = Math.min(Math.max(1, scale + delta), 4);
        
        if (scale === 1) pos = { x: 0, y: 0 };
        img.style.transform = `scale(${scale}) translate(${pos.x}px, ${pos.y}px)`;
      }, { passive: false });

      // Arrastre básico
      let isDragging = false;
      let startPos = { x: 0, y: 0 };

      img.addEventListener('mousedown', (e) => {
        if (scale > 1) {
          isDragging = true;
          startPos = { x: e.clientX - pos.x, y: e.clientY - pos.y };
        }
      });

      window.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        pos = { x: e.clientX - startPos.x, y: e.clientY - startPos.y };
        img.style.transform = `scale(${scale}) translate(${pos.x}px, ${pos.y}px)`;
      });

      window.addEventListener('mouseup', () => isDragging = false);
    });
  }

  // Inicialización compatible con Astro (incluyendo View Transitions)
  initEducationModals();
  document.addEventListener('astro:after-swap', initEducationModals);
</script>
